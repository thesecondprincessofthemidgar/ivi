# .env.dev
DEBUG=1
DJANGO_SETTINGS_MODULE=mysite.settings
DATABASE_URL=postgres://postgres@db:5432/ivi_dev

OPENAI_API_KEY=your_openai_api_key_here

# proxy all traffic through ss-local container
ALL_PROXY=socks5://ss-local:1080
HTTPS_PROXY=socks5://ss-local:1080

# still allow Django→Postgres to skip the proxy
NO_PROXY=127.0.0.1,localhost,db